# shellcheck shell=bash
# 共有エイリアス。dotfilesで管理する。
# Ubuntu標準の ~/.bashrc が ~/.bash_aliases を自動でsourceするため、
# このファイルを ~/.bash_aliases にリンクするだけで読み込まれる。
#
# マシン固有のエイリアスはここには書かず、末尾でsourceする
# aliases.local (雛形から生成・gitには含めない) に記述する。

# --- git ---
alias g='git'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate'
alias gc='git commit'
alias gco='git checkout'
alias gb='git branch'

# --- ファイル操作 ---
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'

# --- devcontainer ---
function devcu() {
  devcontainer up --dotfiles-repository https://github.com/aobatact/dotfiles.git $*
}
function devce() {
  devcontainer exec $*
}
function devcs() {
  local ids
  ids=$(docker ps -q --filter "label=devcontainer.local_folder=$(pwd)")
  [ -z "$ids" ] && { echo "停止対象の devcontainer がありません"; return 0; }
  docker stop $ids
}
function devcd() {
  local ids
  ids=$(docker ps -q -a --filter "label=devcontainer.local_folder=$(pwd)")
  [ -z "$ids" ] && { echo "停止対象の devcontainer がありません"; return 0; }
  docker rm -f $ids
}

# --- マシン固有エイリアスを読み込む(あれば) ---
_aliases_local="${XDG_CONFIG_HOME:-$HOME/.config}/shell/aliases.local"
[ -f "$_aliases_local" ] && . "$_aliases_local"
unset _aliases_local
